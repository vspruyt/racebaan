{
  "name": "racebaan",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "preworker:dev": "pnpm build",
    "worker:dev": "wrangler dev",
    "preworker:dev:lan": "pnpm build",
    "worker:dev:lan": "wrangler dev --ip 0.0.0.0",
    "worker:deploy": "wrangler deploy",
    "worker:release": "wrangler d1 migrations apply DB --remote && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "vite": "^4.5.14",
    "vitest": "^0.34.6",
    "wrangler": "4.84.0"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "three": "^0.184.0"
  }
}
